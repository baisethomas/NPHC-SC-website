{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev -p 9002",
    "genkit:dev": "genkit start -- tsx src/ai/dev.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev.ts",
    "prebuild": "npm run typecheck",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "test": "vitest run --exclude \"tests/rules/**\"",
    "test:watch": "vitest",
    "test:rules": "firebase emulators:exec --project nphc-solano-rules-test --only firestore,storage \"vitest run tests/rules/firebase-rules.test.ts\"",
    "migrate:roles": "tsx scripts/migrate-roles.ts",
    "env:check": "node scripts/check-env.js",
    "env:check:ci": "node scripts/check-env.js --ci",
    "audit:dependencies": "node scripts/audit-dependencies.mjs"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jsdom": "^27.0.0",
    "@types/react": "19.2.7",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "firebase-tools": "^15.23.0",
    "jsdom": "^27.3.0",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "react-google-places-autocomplete": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "@genkit-ai/next": {
      "zod": "$zod"
    },
    "genkit": {
      "zod": "$zod"
    },
    "@genkit-ai/googleai": {
      "zod": "$zod"
    }
  },
  "dependencies": {
    "@genkit-ai/googleai": "^1.26.0",
    "@genkit-ai/next": "^1.26.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@tailwindcss/postcss": "^4.1.18",
    "@tiptap/extension-placeholder": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "@types/dompurify": "^3.0.5",
    "autoprefixer": "^10.4.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.0",
    "genkit": "^1.26.0",
    "isomorphic-dompurify": "^3.19.0",
    "lucide-react": "^0.561.0",
    "next": "^16.0.10",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-day-picker": "^9.12.0",
    "react-dom": "^19.2.3",
    "react-google-places-autocomplete": "^4.1.0",
    "react-hook-form": "^7.68.0",
    "recharts": "^3.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.13"
  }
}
